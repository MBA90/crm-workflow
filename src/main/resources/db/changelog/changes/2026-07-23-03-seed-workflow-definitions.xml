<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- account | CREATE : single approver, then a compliance approver that can bounce back to step 1 -->
    <changeSet id="1-seed-account-create-definition" author="m.abdelhadi" context="seed">
        <insert tableName="workflow_definitions">
            <column name="definition_id" value="11111111-1111-1111-1111-111111111101"/>
            <column name="entity_type" value="ACCOUNT"/>
            <column name="action" value="CREATE"/>
            <column name="name" value="Account Creation Approval"/>
            <column name="version" valueNumeric="1"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>
        <insert tableName="workflow_definition_steps">
            <column name="step_id" value="11111111-1111-1111-1111-111111111102"/>
            <column name="definition_id" value="11111111-1111-1111-1111-111111111101"/>
            <column name="step_order" valueNumeric="1"/>
            <column name="step_name" value="Manager Review"/>
            <column name="approver_role" value="manager"/>
            <column name="approval_type" value="SINGLE"/>
            <column name="sla_hours" valueNumeric="24"/>
            <column name="on_reject" value="TERMINATE"/>
        </insert>
        <insert tableName="workflow_definition_steps">
            <column name="step_id" value="11111111-1111-1111-1111-111111111103"/>
            <column name="definition_id" value="11111111-1111-1111-1111-111111111101"/>
            <column name="step_order" valueNumeric="2"/>
            <column name="step_name" value="Compliance Review"/>
            <column name="approver_role" value="compliance"/>
            <column name="approval_type" value="SINGLE"/>
            <column name="sla_hours" valueNumeric="48"/>
            <column name="on_reject" value="RETURN_TO_STEP"/>
            <column name="return_to_step" valueNumeric="1"/>
        </insert>
    </changeSet>

    <!-- deal | UPDATE : single-step sales manager sign-off -->
    <changeSet id="2-seed-deal-update-definition" author="m.abdelhadi" context="seed">
        <insert tableName="workflow_definitions">
            <column name="definition_id" value="22222222-2222-2222-2222-222222222201"/>
            <column name="entity_type" value="DEAL"/>
            <column name="action" value="UPDATE"/>
            <column name="name" value="Deal Update Approval"/>
            <column name="version" valueNumeric="1"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>
        <insert tableName="workflow_definition_steps">
            <column name="step_id" value="22222222-2222-2222-2222-222222222202"/>
            <column name="definition_id" value="22222222-2222-2222-2222-222222222201"/>
            <column name="step_order" valueNumeric="1"/>
            <column name="step_name" value="Sales Manager Review"/>
            <column name="approver_role" value="sales_manager"/>
            <column name="approval_type" value="SINGLE"/>
            <column name="sla_hours" valueNumeric="24"/>
            <column name="on_reject" value="TERMINATE"/>
        </insert>
    </changeSet>

    <!-- refund | CREATE : finance review for small refunds, quorum finance committee for large ones (skip rules via condition) -->
    <changeSet id="3-seed-refund-create-definition" author="m.abdelhadi" context="seed">
        <insert tableName="workflow_definitions">
            <column name="definition_id" value="33333333-3333-3333-3333-333333333301"/>
            <column name="entity_type" value="REFUND"/>
            <column name="action" value="CREATE"/>
            <column name="name" value="Refund Approval"/>
            <column name="version" valueNumeric="1"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>
        <insert tableName="workflow_definition_steps">
            <column name="step_id" value="33333333-3333-3333-3333-333333333302"/>
            <column name="definition_id" value="33333333-3333-3333-3333-333333333301"/>
            <column name="step_order" valueNumeric="1"/>
            <column name="step_name" value="Finance Review"/>
            <column name="approver_role" value="finance"/>
            <column name="approval_type" value="SINGLE"/>
            <column name="sla_hours" valueNumeric="12"/>
            <column name="on_reject" value="TERMINATE"/>
            <column name="condition" valueComputed="'{&quot;amount&quot;:{&quot;lt&quot;:500}}'::jsonb"/>
        </insert>
        <insert tableName="workflow_definition_steps">
            <column name="step_id" value="33333333-3333-3333-3333-333333333303"/>
            <column name="definition_id" value="33333333-3333-3333-3333-333333333301"/>
            <column name="step_order" valueNumeric="2"/>
            <column name="step_name" value="Finance Committee"/>
            <column name="approver_role" value="finance_committee"/>
            <column name="approval_type" value="QUORUM"/>
            <column name="quorum_count" valueNumeric="2"/>
            <column name="sla_hours" valueNumeric="24"/>
            <column name="on_reject" value="RETURN_TO_STEP"/>
            <column name="return_to_step" valueNumeric="1"/>
            <column name="condition" valueComputed="'{&quot;amount&quot;:{&quot;gte&quot;:500}}'::jsonb"/>
        </insert>
    </changeSet>

</databaseChangeLog>
