<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- account | CREATE : sales-ops review, then a compliance approver that can bounce back to step 1 -->
    <changeSet id="1-seed-account-create-definition" author="m.abdelhadi" context="seed">
        <insert tableName="workflow_definitions">
            <column name="definition_id" value="00000000-0000-0000-0000-000000000001"/>
            <column name="entity_type" value="ACCOUNT"/>
            <column name="action" value="CREATE"/>
            <column name="name" value="Account Creation Approval"/>
            <column name="version" valueNumeric="1"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>
        <insert tableName="workflow_definition_steps">
            <column name="step_id" value="00000000-0000-0000-0000-000000000002"/>
            <column name="definition_id" value="00000000-0000-0000-0000-000000000001"/>
            <column name="step_order" valueNumeric="1"/>
            <column name="step_name" value="Sales Ops Review"/>
            <column name="approver_role" value="sales_ops"/>
            <column name="approval_type" value="SINGLE"/>
            <column name="sla_hours" valueNumeric="24"/>
            <column name="on_reject" value="TERMINATE"/>
        </insert>
        <insert tableName="workflow_definition_steps">
            <column name="step_id" value="00000000-0000-0000-0000-000000000003"/>
            <column name="definition_id" value="00000000-0000-0000-0000-000000000001"/>
            <column name="step_order" valueNumeric="2"/>
            <column name="step_name" value="Compliance Review"/>
            <column name="approver_role" value="compliance"/>
            <column name="approval_type" value="SINGLE"/>
            <column name="sla_hours" valueNumeric="48"/>
            <column name="on_reject" value="RETURN_TO_STEP"/>
            <column name="return_to_step" valueNumeric="1"/>
        </insert>
    </changeSet>

    <!-- account | UPDATE : single-step account-manager sign-off -->
    <changeSet id="2-seed-account-update-definition" author="m.abdelhadi" context="seed">
        <insert tableName="workflow_definitions">
            <column name="definition_id" value="00000000-0000-0000-0000-000000000004"/>
            <column name="entity_type" value="ACCOUNT"/>
            <column name="action" value="UPDATE"/>
            <column name="name" value="Account Update Approval"/>
            <column name="version" valueNumeric="1"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>
        <insert tableName="workflow_definition_steps">
            <column name="step_id" value="00000000-0000-0000-0000-000000000005"/>
            <column name="definition_id" value="00000000-0000-0000-0000-000000000004"/>
            <column name="step_order" valueNumeric="1"/>
            <column name="step_name" value="Account Manager Review"/>
            <column name="approver_role" value="account_manager"/>
            <column name="approval_type" value="SINGLE"/>
            <column name="sla_hours" valueNumeric="24"/>
            <column name="on_reject" value="TERMINATE"/>
        </insert>
    </changeSet>

    <!-- deal | UPDATE : single-step sales manager sign-off -->
    <changeSet id="3-seed-deal-update-definition" author="m.abdelhadi" context="seed">
        <insert tableName="workflow_definitions">
            <column name="definition_id" value="00000000-0000-0000-0000-000000000006"/>
            <column name="entity_type" value="DEAL"/>
            <column name="action" value="UPDATE"/>
            <column name="name" value="Deal Update Approval"/>
            <column name="version" valueNumeric="1"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>
        <insert tableName="workflow_definition_steps">
            <column name="step_id" value="00000000-0000-0000-0000-000000000007"/>
            <column name="definition_id" value="00000000-0000-0000-0000-000000000006"/>
            <column name="step_order" valueNumeric="1"/>
            <column name="step_name" value="Sales Manager Review"/>
            <column name="approver_role" value="sales_manager"/>
            <column name="approval_type" value="SINGLE"/>
            <column name="sla_hours" valueNumeric="24"/>
            <column name="on_reject" value="TERMINATE"/>
        </insert>
    </changeSet>

    <!-- refund | CREATE : finance review for small refunds, quorum finance committee for large ones (skip rules via condition) -->
    <changeSet id="4-seed-refund-create-definition" author="m.abdelhadi" context="seed">
        <insert tableName="workflow_definitions">
            <column name="definition_id" value="00000000-0000-0000-0000-000000000008"/>
            <column name="entity_type" value="REFUND"/>
            <column name="action" value="CREATE"/>
            <column name="name" value="Refund Approval"/>
            <column name="version" valueNumeric="1"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>
        <insert tableName="workflow_definition_steps">
            <column name="step_id" value="00000000-0000-0000-0000-000000000009"/>
            <column name="definition_id" value="00000000-0000-0000-0000-000000000008"/>
            <column name="step_order" valueNumeric="1"/>
            <column name="step_name" value="Finance Review"/>
            <column name="approver_role" value="finance"/>
            <column name="approval_type" value="SINGLE"/>
            <column name="sla_hours" valueNumeric="12"/>
            <column name="on_reject" value="TERMINATE"/>
            <column name="condition" valueComputed="'{&quot;amount&quot;:{&quot;lt&quot;:500}}'::jsonb"/>
        </insert>
        <insert tableName="workflow_definition_steps">
            <column name="step_id" value="00000000-0000-0000-0000-00000000000a"/>
            <column name="definition_id" value="00000000-0000-0000-0000-000000000008"/>
            <column name="step_order" valueNumeric="2"/>
            <column name="step_name" value="Finance Committee"/>
            <column name="approver_role" value="finance_committee"/>
            <column name="approval_type" value="QUORUM"/>
            <column name="quorum_count" valueNumeric="2"/>
            <column name="sla_hours" valueNumeric="24"/>
            <column name="on_reject" value="RETURN_TO_STEP"/>
            <column name="return_to_step" valueNumeric="1"/>
            <column name="condition" valueComputed="'{&quot;amount&quot;:{&quot;gte&quot;:500}}'::jsonb"/>
        </insert>
    </changeSet>

</databaseChangeLog>
